# Database Configuration for Vercel Deployment
# Copy this file to .env.local and fill in your actual database credentials
# DO NOT commit .env.local to version control

# MySQL Database Host (e.g., from PlanetScale, Railway, Supabase, or AWS RDS)
DB_HOST=your-mysql-host.com

# MySQL Database User
DB_USER=your-database-user

# MySQL Database Password
DB_PASSWORD=your-database-password

# MySQL Database Name
DB_NAME=inventory_db

# (Optional) Database Port (default is 3306 for MySQL)
DB_PORT=3306
